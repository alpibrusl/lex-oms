[13.606484, "o", "        src/demo.lex main\r\n"]
[14.208858, "o", "\r\n  === POST /orders ===\r\n\r\n"]
[14.208878, "o", "  ORD-001  AAPL  buy  100  market  → 201\r\n  ORD-002  MSFT  sell  50  market  → 201\r\n  ORD-003  TSLA  buy  200  market  → 201\r\n\r\n  === POST /execution-reports ===\r\n\r\n"]
[14.208937, "o", "  E-001  ACK  ORD-001           → 200  {\"cl_ord_id\":\"ORD-001\",\"new_state\":\"New\"}\r\n  E-002  partial  50@174.91     → 200  {\"cl_ord_id\":\"ORD-001\",\"new_state\":\"PartiallyFilled\"}\r\n  E-003  fill     50@175.00     → 200  {\"cl_ord_id\":\"ORD-001\",\"new_state\":\"Filled\"}\r\n  E-004  ACK  ORD-002           → 200  {\"cl_ord_id\":\"ORD-002\",\"new_state\":\"New\"}\r\n  E-005  fill    50@418.51      → 200  {\"cl_ord_id\":\"ORD-002\",\"new_state\":\"Filled\"}\r\n  E-006  ACK  ORD-003           → 200  {\"cl_ord_id\":\"ORD-003\",\"new_state\":\"New\"}\r\n\r\n  === GET /blotter ===\r\n\r\n"]
[14.208943, "o", "[\r\n  {\r\n    \"cl_ord_id\": \"ORD-003\",\r\n    \"account\": \"DEFAULT\",\r\n    \"symbol\": \"TSLA\",\r\n    \"state\": \"New\",\r\n    \"filled_qty\": 0,\r\n    \"avg_price\": \"0\"\r\n  },\r\n  {\r\n    \"cl_ord_id\": \"ORD-002\",\r\n    \"account\": \"DEFAULT\",\r\n    \"symbol\": \"MSFT\",\r\n    \"state\": \"Filled\",\r\n    \"filled_qty\": 0,\r\n    \"avg_price\": \"418.51\"\r\n  },\r\n  {\r\n    \"cl_ord_id\": \"ORD-001\",\r\n    \"account\": \"DEFAULT\",\r\n    \"symbol\": \"AAPL\",\r\n    \"state\": \"Filled\",\r\n    \"filled_qty\": 0,\r\n    \"avg_price\": \"175.00\"\r\n  }\r\n]\r\n"]
[14.208968, "o", "\r\n  === GET /positions ===\r\n\r\n[\r\n  {\r\n    \"account\": \"DEFAULT\",\r\n    \"symbol\": \"AAPL\",\r\n    \"qty\": 100,\r\n    \"avg_cost\": \"174.95500000\",\r\n    \"realized_pnl\": \"0\"\r\n  },\r\n  {\r\n    \"account\": \"DEFAULT\",\r\n    \"symbol\": \"MSFT\",\r\n    \"qty\": -50,\r\n    \"avg_cost\": \"418.51\",\r\n    \"realized_pnl\": \"0\"\r\n  }\r\n]\r\n\r\n"]
[14.208973, "o", "  === GET /risk ===\r\n\r\n"]
[14.209002, "o", "{\r\n  \"positions\": [\r\n    {\r\n      \"account\": \"DEFAULT\",\r\n      \"symbol\": \"AAPL\",\r\n      \"qty\": 100,\r\n      \"delta\": 100,\r\n      \"dollar_delta\": \"17491.00\",\r\n      \"gross_notional\": \"17491.00\",\r\n      \"unrealized_pnl\": \"-4.50000000\",\r\n      \"initial_margin\": \"4372.7500\"\r\n    },\r\n    {\r\n      \"account\": \"DEFAULT\",\r\n      \"symbol\": \"MSFT\",\r\n      \"qty\": -50,\r\n      \"delta\": -50,\r\n      \"dollar_delta\": \"-20925.50\",\r\n      \"gross_notional\": \"20925.50\",\r\n      \"unrealized_pnl\": \"0.00\",\r\n      \"initial_margin\": \"5231.3750\"\r\n    }\r\n  ],\r\n  \"net_dollar_delta\": \"-3434.50\",\r\n  \"total_notional\": \"38416.50\",\r\n  \"total_unreal_pnl\": \"-4.50000000\",\r\n  \"total_margin\": \"9604.1250\"\r\n}\r\n"]
[14.211174, "o", "\r\n"]
[15.717903, "o", "\u001b[2m"]
[15.718344, "o", "────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n  \u001b[1m\u001b[32mDONE\u001b[0m\r\n\r\n  Three orders submitted and filled.\r\n  Positions calculated with exact WAAC arithmetic.\r\n  Risk report: delta, notional, margin — all typed, all checked.\r\n"]
[15.718467, "o", "  Every step attested in the append-only trail log.\r\n\r\n\u001b[2m"]
[15.7194, "o", "────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
