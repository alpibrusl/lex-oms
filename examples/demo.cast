[7.220092, "o", "  \u001b[1m\u001b[36mType check — all effects declared before a byte runs\u001b[0m\r\n\u001b[2m────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n\u001b[1m\u001b[34m$\u001b[0m  lex check src/demo.lex\r\n"]
[8.343425, "o", "ok\r\nrequired effects: concurrent, crypto, fs_read, fs_write, io, net, random, sql, time\r\nhint: lex run --allow-effects concurrent,crypto,fs_read,fs_write,io,net,random,sql,time src/demo.lex <fn> [args]\r\n"]
[8.344602, "o", "\u001b[32m\u001b[1m✓  ok\u001b[0m\r\n\r\n"]
